<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Masakan Ibu - Menu</title>
  <link href="/css/output.css" rel="stylesheet">
</head>

<body class="bg-cream text-gray-800">
  <!-- Modal -->
  <div id="detailModal" class="fixed inset-0 z-50 bg-black bg-opacity-50 flex items-center justify-center hidden">
    <div class="bg-white rounded-2xl shadow-lg w-[90%] max-w-xs p-6 relative">
      <button onclick="closeModal()"
        class="absolute top-2 right-2 text-gray-500 hover:text-red-500 text-2xl font-bold">&times;</button>
      <img id="modalImage" src="" alt="Foto Makanan" class="w-full max-h-36 object-cover rounded-lg mb-4" />
      <h3 id="modalNama" class="text-2xl font-bold text-amber-700 mb-2"></h3>
      <p id="modalHarga" class="text-lg font-semibold text-gray-700 mb-4"></p>
      <p id="modalDeskripsi" class="text-sm text-gray-600"></p>
    </div>
  </div>

  <!-- Navbar -->
  <nav class="flex justify-between items-center p-4 shadow bg-yellow-50">
    <!-- <nav class="flex justify-between items-center p-4 shadow bg-white"> -->
    <div class="flex items-center gap-2">
      <!-- <img src="/images/logo.jpg" alt="Logo" class="w-6 h-6"> -->
      <a href="/"><span
          class="font-semibold <%= currentPage === '/' ? 'text-amber-600' : 'hover:text-amber-600' %>">Home</span></a>
    </div>
    <ul class="flex gap-6">
      <li><a href="/menu"
          class="font-semibold <%= currentPage === 'menu' ? 'text-amber-600' : 'hover:text-amber-600' %>">Menu</a></li>
      <li><a href="/tentangKami"
          class="font-semibold <%= currentPage === 'tentangKami' ? 'text-amber-600' : 'hover:text-amber-600' %>">Tentang
          Kami</a></li>
      <li><a href="/kontak"
          class="font-semibold <%= currentPage === 'kontak' ? 'text-amber-600' : 'hover:text-amber-600' %>">Kontak</a>
      </li>
      <li><a href="/keranjang"
          class="font-semibold <%= currentPage === 'keranjang' ? 'text-amber-600' : 'hover:text-amber-600' %>">Keranjang</a>
      </li>
      <% if (userData) { %>
        <li class="relative group cursor-pointer">
          <!-- Gambar profil -->
          <img id="profileBtn" src="/images/dummy_profile.jpg" alt="Profil"
            class="w-8 h-8 rounded-full border-2 border-amber-600 cursor-pointer" />

          <!-- Dropdown menu -->
          <ul id="dropdownMenu"
            class="absolute right-0 mt-2 w-32 bg-white rounded-md shadow-lg hidden transition duration-300 z-10">
            <li>
              <a href="/logout"
                class="block px-4 py-2 text-sm text-red-600 hover:bg-red-100 rounded-md font-semibold">Logout</a>
            </li>
          </ul>
        </li>
        <% } %>
          <!-- <li class="relative group cursor-pointer">
        <img id="profileBtn" src="/images/profile_dummy.jpg" alt="Profil"
          class="w-8 h-8 rounded-full border-2 border-amber-600 cursor-pointer" />
        <ul id="dropdownMenu"
          class="absolute right-0 mt-2 w-32 bg-white rounded-md shadow-lg hidden transition duration-300 z-10">
          <li>
            <a href="/logout"
              class="block px-4 py-2 text-sm text-red-600 hover:bg-red-100 rounded-md font-semibold">Logout</a>
          </li>
        </ul>

      </li> -->
    </ul>
  </nav>

  <!-- Hero Section -->
  <section class="text-center py-16 bg-gradient-to-b from-yellow-50 via-amber-100">
    <!-- <section class="text-center py-10 bg-yellow-50"> -->
    <h1 class="text-4xl font-bold mb-4">Menu Makanan Kami</h1>
    <p class="text-lg mb-4">Nikmati pilihan menu khas buatan ibu yang selalu dibuat dengan cinta!</p>
  </section>

  <!-- Gradasi transisi -->
  <div class="bg-gradient-to-b from-yellow-50 via-yellow-100 to-yellow-100"></div>

  <!-- Menu Makanan -->
  <section id="menu" class="px-4 md:px-12 py-10 bg-yellow-50">
    <h2 class="text-3xl font-bold text-center mb-10 text-amber-700">Menu Makanan</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
      <% if (menuList && menuList.length> 0) { %>
        <% menuList.forEach(item=> { %>
          <div
            class="bg-white rounded-2xl shadow-md hover:shadow-lg transition duration-300 flex flex-col items-center text-center p-4 group">
            <div class="w-full h-36 overflow-hidden rounded-lg mb-4 bg-gray-100">
              <img src="/uploads/<%= item.gambar_menu || 'default.jpg' %>" alt="<%= item.nama %>"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
            </div>

            <h3 class="text-xl font-semibold text-amber-700 mb-2 text-left w-full">
              <%= item.nama_menu %>
            </h3>
            <p class="text-sl font-semibold text-gray-700 mb-4 text-left w-full">
              Rp <%= item.harga_menu ? item.harga_menu.toLocaleString() : 'Harga tidak tersedia' %>
            </p>

            <div class="flex gap-2 w-full mt-2 items-start">
              <!-- Tombol Lihat Detail -->
              <button type="button"
                onclick="openModal('<%= item.nama_menu %>', '<%= item.harga_menu %>', '/uploads/<%= item.gambar_menu %>', '<%= item.deskripsi_menu %>')"
                class="w-1/2 bg-amber-200 text-amber-800 font-semibold text-xs px-3 py-2 rounded-lg hover:bg-amber-300 transition text-center self-start">
                Lihat Detail
              </button>

              <!-- Form Tambah ke Keranjang -->
              <form action="/keranjang/tambah" method="POST" class="w-1/2 add-to-cart-form flex flex-col">
                <input type="hidden" name="id" value="<%= item.id_menu %>">
                <input type="hidden" name="nama" value="<%= item.nama_menu %>">
                <input type="hidden" name="harga" value="<%= item.harga_menu %>">
                <input type="hidden" name="image" value="<%= item.gambar_menu %>">
                <input type="hidden" name="jumlah" value="1" class="jumlah-input">

                <!-- Tombol Tambah ke Keranjang -->

                <button type="button"
                  class="btn-add-cart w-full bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-3 rounded-lg text-xs">
                  + Keranjang
                </button>

                <!-- Kontrol Jumlah & Tombol Checkout (muncul setelah diklik) -->
                <div class="jumlah-control hidden flex flex-col gap-2 mt-2">
                  <div class="flex items-center justify-between gap-2">
                    <button type="button"
                      class="kurang bg-amber-400 px-2 py-1 text-amber-700 font-bold rounded hover:bg-amber-500">−</button>
                    <span class="jumlah-view text-sm font-semibold w-4 text-center">1</span>
                    <button type="button"
                      class="tambah bg-amber-400 px-2 py-1 text-amber-700 font-bold rounded hover:bg-amber-500">+</button>
                  </div>
                  <button type="submit"
                    class="bg-amber-500 hover:bg-amber-600 text-white font-semibold py-1 px-3 rounded-lg text-xs w-full">
                    Tambah ke keranjang
                  </button>
                </div>
              </form>
            </div>
          </div>

          <% }) %>
            <% } else { %>
              <p class="text-center text-gray-600 col-span-full">Menu belum tersedia.</p>
              <% } %>
    </div>
  </section>

  <div class="bg-gradient-to-b from-yellow-50 to-yellow-100"></div>

  <footer class="text-center py-8 bg-gradient-to-b from-yellow-100 via-amber-80 to-yellow-50">
    <h2 class="text-lg font-semibold text-amber-700 mb-4">Services</h2>
    <ul class="flex justify-center gap-6 text-sm text-gray-700 mb-4">
      <li><a href="/" class="hover:text-amber-600 font-semibold">Home</a></li>
      <li><a href="/menu" class="hover:text-amber-600 font-semibold">Menu</a></li>
      <li><a href="/tentangKami" class="hover:text-amber-600 font-semibold">Tentang Kami</a></li>
      <li><a href="/kontak" class="hover:text-amber-600 font-semibold">Kontak</a></li>
    </ul>
    <p class="text-xs text-gray-500">© <%= new Date().getFullYear() %> RA KITCHEN. All rights reserved.</p>
  </footer>

  <script src="/js/client/profileLogout.js"></script>
  <script src="/js/client/detailCard.js"></script>
  <script src="/js/client/menuButton.js"></script>
</body>

</html>