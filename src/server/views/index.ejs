<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Masakan Ibu</title>
  <link href="/css/output.css" rel="stylesheet">
</head>

<body class="bg-cream text-gray-800">
  <!-- Navbar -->
  <%- include('components/header', {isLoggedIn}) %>

  <!-- Hero Section -->
  <section class="text-center py-16 bg-gradient-to-b from-yellow-50 via-amber-100">
    <div class="flex flex-col items-center">
      <img src="/images/logo.jpg" alt="RA Kitchen Logo"
        class="w-32 h-32 mb-4 rounded-xl shadow-lg object-cover border-4 border-white" />
      <!-- <img src="/images/logo.jpg" alt="RA Kitchen Logo" class="w-32 h-auto mb-4"> -->
      <h2 class="text-3xl font-bold text-amber-700 tracking-wide mb-2 drop-shadow-sm">
        Selamat Datang di <span class="text-amber-600">RA KITCHEN</span>
      </h2>
      <p class="text-base text-gray-600 italic max-w-md mx-auto">
        Pesan makanan favorit Anda dengan <span class="text-amber-500 font-medium">mudah</span> dan <span
          class="text-amber-500 font-medium">cepat</span>.
      </p>

      <a href="/menu"
        class="mt-6 inline-block bg-amber-600 text-white px-6 py-3 rounded-full shadow-md hover:bg-amber-700 hover:scale-105 transition-all duration-300">
        🍽️ Lihat Menu
      </a>
    </div>
  </section>

  <!-- Gradasi transisi -->
  <div class="bg-gradient-to-b from-yellow-50 via-amber-100 to-gray-100"></div>

  <!-- Cara memesan -->
  <section class="bg-white py-12">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-10">Cara Memesan</h2>
      <!-- <h2 class="text-2xl font-bold text-center text-amber-600 mb-10">Cara Pesan di RA Kitchen</h2> -->

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 text-center">
        <!-- Step 1 -->
        <div class="flex flex-col items-center">
          <div class="bg-yellow-200 text-amber-600 p-4 rounded-full mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M8 6H21M8 12H21M8 18H21M3 6h.01M3 12h.01M3 18h.01" />
            </svg>
          </div>
          <h3 class="font-semibold text-lg">1. Lihat Menu</h3>
          <p class="text-sm text-gray-600 mt-1">Jelajahi berbagai pilihan makanan yang tersedia.</p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center">
          <div class="bg-yellow-200 text-amber-600 p-4 rounded-full mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 3h18v2H3V3zm3 4h12v2H6V7zm3 4h6v2H9v-2zm-6 4h18v2H3v-2zm3 4h12v2H6v-2z" />
            </svg>
          </div>
          <h3 class="font-semibold text-lg">2. Tambahkan ke Keranjang</h3>
          <p class="text-sm text-gray-600 mt-1">Pilih makanan favoritmu dan masukkan ke keranjang.</p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center">
          <div class="bg-yellow-200 text-amber-600 p-4 rounded-full mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
          </div>
          <h3 class="font-semibold text-lg">3. Isi Biodata</h3>
          <p class="text-sm text-gray-600 mt-1">Masukkan data dirimu untuk pengiriman.</p>
        </div>

        <!-- Step 4 -->
        <!-- <div class="flex flex-col items-center col-span-1 sm:col-span-1 md:col-span-2 md:col-start-1"> -->
        <!-- Step 4 & 5 dalam satu baris tengah -->
        <div class="md:col-span-3 flex flex-col md:flex-row justify-center items-center gap-8">
          <!-- Step 4 -->
          <div class="flex flex-col items-center">
            <div class="bg-yellow-200 text-amber-600 p-4 rounded-full mb-4">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M3 10h2l1 2h13v-2H6.42l-.6-1H3v1zm3 6a2 2 0 104 0 2 2 0 00-4 0zm10 0a2 2 0 104 0 2 2 0 00-4 0z">
                </path>
              </svg>
            </div>
            <h3 class="font-semibold text-lg">4. Selesaikan Pesanan</h3>
            <p class="text-sm text-gray-600 mt-1">Lakukan checkout & tunggu pengirimanmu.</p>
          </div>

          <!-- Step 5 -->
          <div class="flex flex-col items-center">
            <div class="bg-yellow-200 text-amber-600 p-4 rounded-full mb-4">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M3 10h2l1 2h13v-2H6.42l-.6-1H3v1zm3 6a2 2 0 104 0 2 2 0 00-4 0zm10 0a2 2 0 104 0 2 2 0 00-4 0z">
                </path>
              </svg>
            </div>
            <h3 class="font-semibold text-lg">5. Notifikasi Pesanan</h3>
            <p class="text-sm text-gray-600 mt-1">
              Tunggu status pesanan terupdate.
              <br><strong>(Jangan tutup website)</strong>.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>


  <div class="bg-gradient-to-b from-gray-100 to-yellow-100"></div>

  <!-- <footer class="bg-yellow-100 py-8 text-center"> -->
  <footer class="text-center py-8 bg-gradient-to-b from-yellow-100 via-amber-80 to-yellow-50">
    <h2 class="text-lg font-semibold text-amber-700 mb-4">Services</h2>
    <ul class="flex justify-center gap-6 text-sm text-gray-700 mb-4">
      <li><a href="/" class="hover:text-amber-600 font-semibold">Home</a></li>
      <li><a href="/menu" class="hover:text-amber-600 font-semibold">Menu</a></li>
      <li><a href="/tentangKami" class="hover:text-amber-600 font-semibold">Tentang Kami</a></li>
      <li><a href="/kontak" class="hover:text-amber-600 font-semibold">Kontak</a></li>
    </ul>
    <p class="text-xs text-gray-500">© <%= new Date().getFullYear() %> RA KITCHEN. All rights reserved.</p>
  </footer>


  <script src="/js/client/profileLogout.js"></script>
</body>

</html>