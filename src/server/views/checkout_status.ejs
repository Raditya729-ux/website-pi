<body class="text-gray-800 flex flex-col min-h-screen">
  <section class="px-6 md:px-20 py-10 text-center">
    <!-- <h2 class="text-2xl font-bold mb-4">Pesanan Anda</h2> -->
    <section class="px-6 md:px-20 py-10 text-center">
      <h2 class="text-2xl font-bold mb-4">Pesanan Anda</h2>
      <!-- <p class="text-sm italic text-gray-500">Status dari controller: "<%= status %>"</p> Tambahan -->

      <% if (status==='menunggu' ) { %>
        <p class="text-yellow-600 font-semibold">
          Silakan lakukan pembayaran dan unggah bukti transfer.
        </p>
        <% } else if (status==='verifikasi' ) { %>
          <p class="text-orange-600 font-semibold">
            Bukti transfer Anda telah diterima. Menunggu verifikasi admin.
          </p>
          <% } else if (status==='diproses' ) { %>
            <p class="text-green-600 font-semibold">
              Pesanan Anda sedang diproses. Tunggu informasi pengantaran.
            </p>
            <% } else if (status==='diantar' ) { %>
              <p class="text-blue-600 font-semibold">
                Pesanan sedang dalam pengantaran ke lokasi Anda.
              </p>
              <% } else if (status==='sampai' ) { %>
                <p class="text-red-600 font-semibold">
                  Pesanan sudah sampai.
                </p>
                <% } else { %>
                  <p class="text-gray-600 font-semibold">
                    Status pesanan tidak diketahui.
                  </p>
                  <% } %>

    </section>


