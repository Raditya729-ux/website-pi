<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
  <link href="/css/output.css" rel="stylesheet" />
</head>

<body class="text-gray-800 flex flex-col min-h-screen">
  <section class="px-6 md:px-20 py-10 text-center">
    <!-- <h2 class="text-2xl font-bold mb-4">Pesanan Anda</h2> -->
    <section class="px-6 md:px-20 py-10 text-center">
      <h2 class="text-2xl font-bold mb-4">Pesanan Anda</h2>
      <!-- <p class="text-sm italic text-gray-500">Status dari controller: "<%= status %>"</p> Tambahan -->

      <% if (status==='menunggu' ) { %>
        <p class="text-yellow-600 font-semibold">
          Silakan lakukan pembayaran dan unggah bukti transfer.
        </p>
        <% } else if (status==='verifikasi' ) { %>
          <p class="text-orange-600 font-semibold">
            Bukti transfer Anda telah diterima. Menunggu verifikasi admin.
          </p>
          <% } else if (status==='diproses' ) { %>
            <p class="text-green-600 font-semibold">
              Pesanan Anda sedang diproses. Tunggu informasi pengantaran.
            </p>
            <% } else if (status==='diantar' ) { %>
              <p class="text-blue-600 font-semibold">
                Pesanan sedang dalam pengantaran ke lokasi Anda.
              </p>
              <% } else if (status==='sampai' ) { %>
                <p class="text-red-600 font-semibold">Pesanan sudah sampai.</p>
                <% } else if (status==='selesai' ) { %>
                  <p class="text-blue-600 font-semibold">Pesanan Anda sudah selesai. Terima kasih!</p>
                  <a href="/" class="mt-4 inline-block bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
                    Kembali ke Beranda
                  </a>
                  <% } else { %>
                    <p class="text-gray-600 font-semibold">Status pesanan tidak diketahui.</p>
                    <% } %>

    </section>


    <script src="/socket.io/socket.io.js"></script>
    <script>
      const socket = io();

      // Dengar event 'statusUpdated' dari server
      socket.on('statusUpdated', (data) => {
        // Reload otomatis kalau pesanan sesuai dengan user ini
        if (data.userEmail === "<%= userEmail %>") {
          location.reload(); // Atau bisa update DOM tanpa reload
        }
      });

      const status = "<%= status %>";
      console.log("Status pesanan sekarang:", status);
      if (status === 'sampai') {
        alert("Pesanan selesai. Akan diarahkan ke halaman utama...");
        setTimeout(() => {
          window.location.href = '/'; // redirect ke landing page
        }, 3000); // delay 3 detik
      }
    </script>

  </section>
</body>

</html>