<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <title>Login User</title>
  <link rel="stylesheet" href="/css/output.css" />
</head>

<body class="bg-white min-h-screen flex items-center justify-center">
  <div
    class="w-full max-w-sm bg-gradient-to-b from-yellow-100 via-yellow-50 to-white px-6 py-6 rounded-xl shadow-lg text-center">

    <!-- Logo -->
    <img src="/images/logo.jpg" alt="RA Kitchen Logo"
      class="w-20 h-20 mb-3 mx-auto rounded-xl shadow object-cover border-4 border-white" />

    <!-- Judul -->
    <h2 class="text-lg font-bold mb-4">Silakan Login!</h2>

    <!-- Pesan error (jika ada) -->
    <% if (error) { %>
      <p class="text-red-600 text-sm mb-3">
        <%= error %>
      </p>
      <% } %>

        <!-- Form Login -->
        <form action=<%= '/user/login?ref='+referal %> method="POST" class="space-y-3 text-left text-sm">
          <div>
            <label for="email" class="block font-medium mb-1">Email</label>
            <input type="email" name="email" required placeholder="Masukkan email anda..."
              class="w-full border border-yellow-300 px-3 py-1.5 rounded-md focus:outline-none focus:ring-1 focus:ring-yellow-500" />
          </div>
          <div>
            <label for="password" class="block font-medium mb-1">Kata Sandi</label>
            <input type="password" name="password" required placeholder="Masukkan kata sandi..."
              class="w-full border border-yellow-300 px-3 py-1.5 rounded-md focus:outline-none focus:ring-1 focus:ring-yellow-500" />
          </div>
          <button type="submit"
            class="w-full bg-amber-500 text-white py-2 mt-1 rounded-md hover:bg-amber-600 transition-all text-sm font-semibold">Login</button>
        </form>

        <p class="mt-6 text-center text-sm text-gray-600">
          Belum punya akun?
          <a href=<%= "/userRegister?ref=" + referal %> class="font-medium text-amber-600 hover:text-amber-500">
            Daftar sekarang
          </a>
        </p>

        <!-- Link ke register -->
        <!-- <p class="mt-4 text-sm text-gray-600">
          Belum punya akun? <a href="/user/register" class="text-amber-600 underline">Daftar di sini</a>
        </p> -->

        <!-- Link ke admin -->
        <!-- <p class="mt-1 text-sm text-gray-600">
          Masuk sebagai <a href="/admin/login" class="text-green-600 underline">Admin</a>
        </p> -->
  </div>
</body>

</html>



