<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>
  <link href="/css/output.css" rel="stylesheet" />
</head>

<body class="bg-yellow-50 font-sans">
  <div class="flex overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-64 bg-amber-800 text-white flex flex-col h-screen sticky top-0">
      <div class="text-xl font-bold px-6 py-4">
        RA Kitchen
      </div>
      <nav class="flex-1 px-4 py-2 bg-yellow-600 space-y-1">
        <a href="/adminDashboard?section=transaksi"
          class="block w-full text-left py-2 px-3 rounded transition duration-200
      <%= currentPage === 'transaksi' ? 'bg-amber-700 text-white font-semibold' : 'hover:bg-amber-700 hover:text-white' %>">
          Transaksi
        </a>
        <a href="/adminDashboard?section=menu" class="block w-full text-left py-2 px-3 rounded transition duration-200
      <%= currentPage === 'menu' ? 'bg-amber-700 text-white font-semibold' : 'hover:bg-amber-700 hover:text-white' %>">
          Makanan
        </a>
        <a href="/admin/logout"
          class="block w-full text-left py-2 px-3 rounded transition duration-200 hover:bg-red-600 hover:text-white">
          Logout
        </a>
      </nav>
      <footer class="text-sm text-center px-4 py-4">
        &copy; 2025 RA Kitchen
      </footer>
    </aside>
    <!-- Main Content Area -->
    <main class="flex-1 p-6 overflow-auto max-h-screen">
      <!-- Section: Dashboard -->
      <% if (currentPage==='transaksi' ) { %>
        <section id="dashboardSection">
          <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold">Halaman Dashboard</h1>
          </div>
          <div class="bg-white rounded-lg shadow p-4">
            <h2 class="text-lg font-semibold mb-4">Daftar Histori Transaksi</h2>
            <div class="overflow-x-auto">
              <table class="table-auto w-full border border-gray-200">
                <thead>
                  <tr class="bg-yellow-100">
                    <th class="px-4 py-2 text-left">No</th>
                    <th class="px-4 py-2 text-left">Kode Invoice</th>
                    <th class="px-4 py-2 text-left">Tanggal</th>
                    <th class="px-4 py-2 text-left">Pembeli</th>
                    <th class="px-4 py-2 text-left">Kontak</th>
                    <th class="px-4 py-2 text-left">Status</th>
                    <th class="px-4 py-2 text-left">Detail Menu</th>
                    <th class="px-4 py-2 text-left">Bukti Transfer DP</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (transaksiList.length> 0) { %>
                    <% transaksiList.forEach((trx, index)=> { %>
                      <tr class="border-t">
                        <td class="px-4 py-2">
                          <%= index + 1 %>
                        </td>
                        <td class="px-4 py-2">
                          <%= trx.invoice_id %>
                        </td>
                        <td class="px-4 py-2">
                          <%= trx.tanggal.toLocaleDateString('id-ID') %>
                        </td>
                        <td class="px-4 py-2">
                          <%= trx.nama_pembeli %>
                        </td>
                        <td class="px-4 py-2 text-sm">
                          <strong>Email:</strong>
                          <%= trx.email %><br>
                            <strong>Telp:</strong>
                            <%= trx.telepon %><br>
                              <strong>Alamat:</strong>
                              <%= trx.alamat %>
                        </td>
                        <td class="px-4 py-2">
                          <% if (trx.bukti && trx.status==='menunggu' ) { %>
                            <span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded-full">Menunggu
                              Verifikasi</span>
                            <form method="POST" action="/admin/ubah_status/<%= trx.invoice_id %>?to=diproses"
                              class="mt-1">
                              <button class="bg-blue-500 text-white text-xs px-2 py-1 rounded hover:bg-blue-600">
                                Verifikasi & Proses
                              </button>
                            </form>

                            <% } else if (trx.status==='verifikasi' ) { %>
                              <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full">Menunggu
                                Diproses</span>
                              <form method="POST" action="/admin/ubah_status/<%= trx.invoice_id %>?to=diproses"
                                class="mt-1">
                                <button class="bg-orange-500 text-white text-xs px-2 py-1 rounded hover:bg-orange-600">
                                  Proses Sekarang
                                </button>
                              </form>

                              <% } else if (trx.status==='diproses' ) { %>
                                <span
                                  class="bg-orange-100 text-orange-800 text-xs px-2 py-1 rounded-full">Diproses</span>
                                <form method="POST" action="/admin/ubah_status/<%= trx.invoice_id %>?to=diantar"
                                  class="mt-1">
                                  <button class="bg-green-500 text-white text-xs px-2 py-1 rounded hover:bg-green-600">
                                    Tandai Telah Dikirim
                                  </button>
                                </form>

                                <% } else if (trx.status==='diantar' ) { %>
                                  <span
                                    class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full">Dikirim</span>
                                  <form method="POST" action="/admin/ubah_status/<%= trx.invoice_id %>?to=sampai"
                                    class="mt-1">
                                    <button class="bg-red-500 text-white text-xs px-2 py-1 rounded hover:bg-green-600">
                                      Tandai Telah Sampai
                                    </button>
                                  </form>

                                  <% } else if (trx.status==='sampai' ) { %>
                                    <span class="bg-red-500 text-white text-xs px-2 py-1 rounded-full">Sampai</span>

                                    <% } else if (!trx.status && trx.bukti) { %>
                                      <!-- Buat jaga-jaga kalau status belum diset tapi bukti udah ada -->
                                      <span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded-full">Perlu
                                        Verifikasi</span>
                                      <form method="POST" action="/admin/ubah_status/<%= trx.invoice_id %>?to=diproses"
                                        class="mt-1">
                                        <button
                                          class="bg-blue-500 text-white text-xs px-2 py-1 rounded hover:bg-blue-600">
                                          Verifikasi & Proses
                                        </button>
                                      </form>

                                      <% } else { %>

                                        <span class="bg-gray-300 text-gray-800 text-xs px-2 py-1 rounded-full">Status
                                          Tidak
                                          Diketahui</span>
                                        <% } %>
                        </td>

                        <td class="px-4 py-2">
                          <ul class="list-disc pl-4">
                            <% trx.menu.forEach(item=> { %>
                              <li>
                                <%= item.nama %> (x<%= item.jumlah %>) - Rp <%= item.harga_menu.toLocaleString('id-ID') %>
                              </li>
                              <% }) %>
                          </ul>
                        </td>
                        <td>
                          <% if (trx.bukti) { %>
                            <a href="<%= trx.bukti %>" target="_blank">
                              <img src="<%= trx.bukti %>" alt="Bukti Transfer" width="80"
                                class="hover:opacity-80 transition" />
                            </a>
                            <br />
                            <a href="<%= trx.bukti %>" download
                              class="text-blue-600 hover:underline text-sm">Download</a>
                            <% } else { %>
                              <span style="color: gray;">Belum upload</span>
                              <% } %>
                        </td>
                      </tr>
                      <% }) %>
                        <% } else { %>
                          <tr>
                            <td colspan="6" class="px-4 py-4 text-center text-gray-500">Belum ada transaksi</td>
                          </tr>
                          <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </section>
        <% } %>
          <!-- Section: CRUD Menu -->
          <% if (currentPage==='menu' ) { %>
            <section id="crudSection">
              <h1 class="text-2xl font-bold mb-6 text-center">Upload Menu Baru</h1>
              <div class="flex justify-center">
                <form action="/adminDashboard/upload" method="POST" enctype="multipart/form-data"
                  class="bg-white p-8 rounded-lg shadow-md w-full max-w-md">
                  <div class="mb-4">
                    <label for="nama" class="block text-gray-700 mb-2">Nama Makanan</label>
                    <input type="text" id="nama" name="nama" class="w-full p-2 border border-gray-300 rounded"
                      required />
                  </div>
                  <div class="mb-4">
                    <label for="harga" class="block text-gray-700 mb-2">Harga</label>
                    <input type="number" id="harga" name="harga" class="w-full p-2 border border-gray-300 rounded"
                      required />
                  </div>
                  <div class="mb-4">
                    <label for="deskripsi" class="block text-gray-700 mb-2">Detail Makanan</label>
                    <textarea type="text" id="deskripsi" name="deskripsi" rows="4"
                      class="w-full p-2 border border-gray-300 rounded resize-none" required></textarea>
                  </div>
                  <div class="mb-6">
                    <label for="image" class="block text-gray-700 mb-2">Upload Gambar</label>
                    <input type="file" id="image" name="image" accept="image/*"
                      class="w-full p-2 border border-gray-300 rounded" required />
                  </div>
                  <button type="submit"
                    class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded">
                    Upload
                  </button>
                </form>
              </div>
              <h2 class="text-2xl font-semibold mt-10 mb-4 text-center">Daftar Menu</h2>
              <div class="w-full overflow-x-auto">
                <table class="w-full max-w-5xl bg-white rounded-lg shadow-md overflow-hidden text-left text-sm">
                  <thead class="bg-gray-200 text-gray-700 uppercase">
                    <tr>
                      <th class="px-4 py-3">Gambar</th>
                      <th class="px-4 py-3">Nama</th>
                      <th class="px-4 py-3">Harga</th>
                      <th class="px-4 py-3">Aksi</th>
                    </tr>
                  </thead>
                  <tbody class="text-gray-700">
                    <% menuList.forEach(menu=> { %>
                      <tr class="border-b">
                        <td class="px-4 py-2">
                          <img src="/uploads/<%= menu.gambar_menu %>" alt="menu" class="h-16 w-16 object-cover rounded" />
                        </td>
                        <td class="px-4 py-2">
                          <%= menu.nama_menu %>
                        </td>
                        <td class="px-4 py-2">Rp <%= menu.harga_menu %>
                        </td>
                        <td class="px-4 py-2 space-x-2">
                          <button type="button"
                            class="edit-button bg-yellow-400 hover:bg-yellow-500 text-white px-3 py-1 rounded"
                            data-id="<%= menu.id_menu %>" data-nama="<%= menu.nama_menu %>" data-harga="<%= menu.harga_menu %>"
                            data-deskripsi="<%= menu.deskripsi %>">Edit</button>
                          <button type="button"
                            class="delete-button bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded"
                            data-id="<%= menu.id_menu %>">Hapus</button>
                          <!-- <a href="/adminDashboard/delete/<%= menu.id %>" onclick="return confirm('Yakin ingin hapus?')"
                            class="bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded">Hapus</a> -->
                        </td>
                      </tr>
                      <% }) %>
                  </tbody>
                </table>
              </div>
              <!-- Modal Edit -->
              <div id="edit-popup"
                class="hidden fixed inset-0 bg-black bg-opacity-50 flex justify-center items-center z-50">
                <div class="bg-white p-6 rounded-lg shadow-lg w-full max-w-md">
                  <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-bold">Edit Menu</h2>
                    <button id="close-popup" class="text-red-500 text-2xl leading-none">&times;</button>
                  </div>
                  <form id="edit-form" method="POST" enctype="multipart/form-data">
                    <input type="hidden" id="edit-id" name="id" />
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700">Nama Makanan</label>
                      <input type="text" id="edit-nama" name="nama"
                        class="mt-1 block w-full border border-gray-300 rounded-md p-2" required />
                    </div>
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700">Harga</label>
                      <input type="number" id="edit-harga" name="harga"
                        class="mt-1 block w-full border border-gray-300 rounded-md p-2" required />
                    </div>
                    <div class="mb-4">
                      <label class="block text-gray-700 mb-2">Detail Makanan</label>
                      <textarea id="deskripsi" name="deskripsi" rows="4"
                        class="w-full p-2 border border-gray-300 rounded resize-none" required></textarea>
                    </div>
                    <div class="mb-4">
                      <label class="block text-sm font-medium text-gray-700">Gambar Baru (Opsional)</label>
                      <input type="file" name="image" class="mt-1 block w-full border border-gray-300 rounded-md p-2" />
                    </div>
                    <button type="submit"
                      class="w-full bg-green-600 text-white py-2 rounded hover:bg-green-700">Update</button>
                  </form>
                </div>
              </div>

              <!-- Modal Hapus -->
              <div id="delete-popup"
                class="hidden fixed inset-0 bg-black bg-opacity-50 flex justify-center items-center z-50">
                <div class="bg-white p-6 rounded-lg shadow-lg w-full max-w-sm">
                  <div class="mb-4 text-center">
                    <h2 class="text-xl font-bold text-red-600">Konfirmasi Hapus</h2>
                    <p class="text-gray-700 mt-2">Apakah Anda yakin ingin menghapus menu ini?</p>
                  </div>
                  <div class="flex justify-center space-x-4 mt-6">
                    <form id="delete-form" method="GET">
                      <button type="submit"
                        class="bg-red-500 hover:bg-red-600 text-white font-semibold py-2 px-4 rounded">
                        Hapus
                      </button>
                    </form>
                    <button id="cancel-delete"
                      class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-semibold py-2 px-4 rounded">
                      Batal
                    </button>
                  </div>
                </div>
              </div>

            </section>
            <% } %>
    </main>
  </div>
  <script src="/js/admin/adminInteractive.js"></script>
</body>

</html>