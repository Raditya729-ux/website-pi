<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <title>Daftar Akun - RA KITCHEN</title>
    <link href="/css/output.css" rel="stylesheet">
</head>

<body class="bg-white min-h-screen flex items-center justify-center">
    <div class="w-full max-w-md bg-gradient-to-b from-yellow-100 via-yellow-50 to-white p-8 rounded-2xl shadow-xl">

        <img src="/images/logo.jpg" alt="RA Kitchen Logo"
            class="w-20 h-20 mb-3 mx-auto rounded-xl shadow object-cover border-4 border-white" />

        <!-- Judul -->
        <h2 class="text-lg text-center font-bold mb-3">Silahkan Daftar!</h2>

        <!-- Form -->
        <form action="/userRegister" method="POST" class="space-y-3 text-left text-sm">
            <div>
                <label for="nama" class="block font-medium mb-1">Nama Lengkap</label>
                <input type="text" name="nama" required placeholder="Masukkan nama anda..."
                    class="w-full border border-yellow-300 px-3 py-1.5 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-yellow-500">
            </div>
            <div>
                <label for="email" class="block font-medium mb-1">Email</label>
                <input type="email" name="email" required placeholder="Masukkan email anda..."
                    class="w-full border border-yellow-300 px-3 py-1.5 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-yellow-500">
            </div>
            <div>
                <label for="telepon" class="block font-medium mb-1">Nomor Telepon</label>
                <input type="text" name="telepon" required placeholder="Masukkan nomor telepon anda..."
                    class="w-full border border-yellow-300 px-3 py-1.5 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-yellow-500">
            </div>
            <div>
                <label for="password" class="block font-medium mb-1">Kata Sandi</label>
                <input type="password" name="password" required placeholder="Masukkan kata sandi..."
                    class="w-full border border-yellow-300 px-3 py-1.5 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-yellow-500">
            </div>

            <button type="submit"
                class="w-full bg-amber-500 text-white py-2 mt-1 rounded-md hover:bg-amber-600 transition-all text-sm font-semibold">Daftar</button>
        </form>

        <!-- Link login -->
        <p class="mt-3 text-sm text-center text-gray-600">
            Sudah punya akun? <a href="/user/login" class="text-amber-600 underline">Masuk di sini</a>
        </p>

        <p class="mt-2 text-center text-sm text-gray-600">
            Masuk sebagai <a href="/admin/login" target="_blank"
                class="text-green-600 font-medium underline">Admin</a>
        </p>
        
