<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login Admin</title>
  <link href="/css/output.css" rel="stylesheet" />
</head>

<body class="bg-white flex items-center justify-center min-h-screen">
  <div
    class="w-full max-w-sm bg-gradient-to-b from-yellow-100 via-yellow-50 to-white px-6 py-6 rounded-xl shadow-lg text-center">

    <!-- Logo -->
    <img src="/images/logo.jpg" alt="RA Kitchen Logo"
      class="w-20 h-20 mb-3 mx-auto rounded-xl shadow object-cover border-4 border-white" />

    <!-- Judul -->
    <h2 class="text-lg font-bold mb-4">Login Admin</h2>

    <!-- Error Message -->
    <% if (typeof error !=='undefined' && error) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-2 rounded mb-4 text-sm">
        <%= error %>
      </div>
      <% } %>

        <!-- Form Login -->
        <form action="/admin/login" method="POST" class="space-y-3 text-left text-sm">
          <div>
            <label class="block font-medium mb-1 text-gray-800">Email</label>
            <input type="email" name="email" required placeholder="Masukkan email admin..."
              class="w-full border border-yellow-300 px-3 py-1.5 rounded-md focus:outline-none focus:ring-1 focus:ring-yellow-500" />
          </div>
          <div>
            <label class="block font-medium mb-1 text-gray-800">Kata Sandi</label>
            <input type="password" name="password" required placeholder="Masukkan kata sandi..."
              class="w-full border border-yellow-300 px-3 py-1.5 rounded-md focus:outline-none focus:ring-1 focus:ring-yellow-500" />
          </div>
          <button type="submit"
            class="w-full bg-amber-500 text-white py-2 mt-1 rounded-md hover:bg-amber-600 transition-all text-sm font-semibold">Login</button>
        </form>

        <!-- Kembali ke login user -->
        <!-- <p class="mt-4 text-sm text-gray-600">
          Masuk sebagai <a href="/user/login" class="text-green-600 underline">User</a>
        </p> -->
  </div>
</body>

</html>



