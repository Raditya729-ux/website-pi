<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tentang Kami</title>
  <link href="/css/output.css" rel="stylesheet" />
</head>

<body class="bg-amber-50 text-gray-800"></body>
<!-- Navbar -->
<nav class="flex justify-between items-center p-4 shadow bg-yellow-50">
  <!-- <nav class="flex justify-between items-center p-4 shadow bg-white"> -->
  <div class="flex items-center gap-2">
    <img src="/images/logo.jpg" alt="Logo" class="w-6 h-6">
    <a href="/"><span
        class="font-semibold <%= currentPage === '/' ? 'text-amber-600' : 'hover:text-amber-600' %>">Home</span></a>
  </div>
  <ul class="flex gap-6">
    <li><a href="/menu"
        class="font-semibold <%= currentPage === 'menu' ? 'text-amber-600' : 'hover:text-amber-600' %>">Menu</a></li>
    <li><a href="/tentangKami"
        class="font-semibold <%= currentPage === 'tentangKami' ? 'text-amber-600' : 'hover:text-amber-600' %>">Tentang
        Kami</a></li>
    <li><a href="/kontak"
        class="font-semibold <%= currentPage === 'kontak' ? 'text-amber-600' : 'hover:text-amber-600' %>">Kontak</a>
    </li>
    <li><a href="/keranjang"
        class="font-semibold <%= currentPage === 'keranjang' ? 'text-amber-600' : 'hover:text-amber-600' %>">Keranjang</a>
    </li>
    <li class="relative group cursor-pointer">
      <!-- Gambar profil -->
      <img id="profileBtn" src="/images/profile_dummy.jpg" alt="Profil"
        class="w-8 h-8 rounded-full border-2 border-amber-600 cursor-pointer" />

      <!-- Dropdown menu -->
      <ul id="dropdownMenu"
        class="absolute right-0 mt-2 w-32 bg-white rounded-md shadow-lg hidden transition duration-300 z-10">
        <li>
          <a href="/logout"
            class="block px-4 py-2 text-sm text-red-600 hover:bg-red-100 rounded-md font-semibold">Logout</a>
        </li>
      </ul>

    </li>
  </ul>
</nav>

<!-- Hero Section -->
<section class="text-center py-16 bg-gradient-to-b from-yellow-50 via-amber-100">
  <!-- <section class="py-12 px-6 md:px-20 text-center bg-white"> -->
  <h1 class="text-3xl md:text-4xl font-bold mb-4">Tentang Kami</h1>
  <p class="text-gray-600 max-w-2xl mx-auto">
    Kami percaya makanan rumahan adalah bentuk cinta yang paling sederhana. Di dapur kami, setiap hidangan dibuat dengan
    rasa hangat seperti buatan ibu sendiri.
  </p>
</section>

<!-- Gradasi transisi -->
<div class="bg-gradient-to-b from-yellow-50 via-amber-100 to-gray-100"></div>

<!-- Content -->
<section class="px-6 md:px-20 py-10 grid md:grid-cols-2 items-center bg-white">
  <img src="/images/logo.jpg" alt="Dapur kami"
  class="w-48 h-auto mx-auto rounded-lg shadow" />
  <!-- <img src="/images/logo.jpg" alt="Dapur kami" class="rounded-lg shadow-md"> -->
  <div class="text-left  md:pl-4">
    <h2 class="text-2xl font-semibold mb-3">Cita Rasa Asli, Dari Dapur Kami</h2>
    <p class="text-gray-700 mb-4">
      Sejak 2024, kami menyajikan makanan khas rumahan dengan bahan-bahan segar dan resep keluarga. Kami berkomitmen
      untuk memberikan rasa yang tak hanya lezat, tapi juga membawa kenangan.
    </p>
    <p class="text-gray-700">
      Kami adalah tim kecil dengan semangat besar dalam menyajikan yang terbaik untuk Anda dan keluarga.
    </p>
  </div>
</section>

<!-- Footer -->
<footer class="text-center py-8 bg-gradient-to-b from-yellow-100 via-amber-80 to-yellow-50">
  <h2 class="text-lg font-semibold text-amber-700 mb-4">Services</h2>
  <ul class="flex justify-center gap-6 text-sm text-gray-700 mb-4">
    <li><a href="/" class="hover:text-amber-600 font-semibold">Home</a></li>
    <li><a href="/menu" class="hover:text-amber-600 font-semibold">Menu</a></li>
    <li><a href="/tentangKami" class="hover:text-amber-600 font-semibold">Tentang Kami</a></li>
    <li><a href="/kontak" class="hover:text-amber-600 font-semibold">Kontak</a></li>
  </ul>
  <p class="text-xs text-gray-500">© <%= new Date().getFullYear() %> RA KITCHEN. All rights reserved.</p>
</footer>
<!-- <footer class="text-center py-6 bg-white text-sm text-gray-500">
  &copy; 2025 Warung Ibu. All rights reserved.
</footer> -->

<script src="/js/client/profileLogout.js"></script>
</body>

</html>